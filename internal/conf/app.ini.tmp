RUN_MODE = release

[server]

HTTP_PORT     = @HTTP_PORT@
READ_TIMEOUT  = 1000
WRITE_TIMEOUT = 1000

[host]

HOST_TEST     =
HOST_RELEASE  =

[mysql]

MYSQL_HOST     = @MYSQL_HOST@
MYSQL_PORT     = @MYSQL_PORT@
MYSQL_USER     = @MYSQL_USER@
MYSQL_PASSWORD = @MYSQL_PASSWORD@
MYSQL_DB       = @MYSQL_DB@